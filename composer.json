{
    "name": "ahmadirfansyah/php-app-devops",
    "description": "Aplikasi PHP sederhana untuk praktikum CI/CD Jenkins + Docker",
    "type": "project",
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    }
}
